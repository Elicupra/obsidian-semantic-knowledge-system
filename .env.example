# Semantix - Configuration Template
# Copy this file to .env and fill in your API keys

# Groq - GPU accelerators for AI inference (free tier available)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# OpenRouter - Unified API for 200+ LLMs
# Get your key at: https://openrouter.ai/settings
OPENROUTER_API_KEY=

# OpenAI - GPT-4, GPT-4o models
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini - Google AI models
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude - Claude 3.5 Sonnet
# Get your key at: https://console.anthropic.com
CLAUDE_API_KEY=